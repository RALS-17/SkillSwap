rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users Collection
    // Anyone can read user profiles (for browsing/searching)
    // Users can only write/update their own profile
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Swap Requests Collection
    // Users can read all requests (for now, you can restrict later)
    // Authenticated users can create and update requests
    match /swapRequests/{requestId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null;
    }
    
    // Chats Collection
    // Authenticated users can read and write chats
    // More permissive to avoid blocking issues
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      
      // Messages Subcollection
      // Authenticated users can read and write messages
      match /messages/{messageId} {
        allow read, write: if request.auth != null;
      }
    }
    
    // Skills Collection (if you add one for categories)
    match /skills/{skillId} {
      allow read: if true;
      allow write: if false; // Only admins can modify skills
    }
  }
}
